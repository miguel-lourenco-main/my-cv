        { "name": "categories", "path": "/", "steps": [ { "wait": 1000 }, { "optional": [ { "reveal": ["#categories", 80] }, { "wait": 500 } ] }, { "shot": "categories" } ] },
        { "name": "how_it_works", "path": "/", "steps": [ { "wait": 1000 }, { "optional": [ { "reveal": ["#how-it-works", 80] }, { "wait": 500 } ] }, { "shot": "how_it_works" } ] },
        { "name": "agents_list", "path": "/agents", "settle": 1200 },
