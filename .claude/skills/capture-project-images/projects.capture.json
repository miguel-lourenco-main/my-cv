{
  "_comment": "LIVING CACHE of per-project shot plans, keyed by imageDir (CV id, or repo slug for adopted projects). Targets are NOT chosen here — the skill DISCOVERS them via discover-projects.mjs (cloud+local+catalog merge), the user selects, then the skill upserts/refreshes the selected project's entry from its source before capturing. Hand-tuned login/theme/custom scene steps are preserved across refreshes. repoDir should point at the project's webDir (monorepo subdir if applicable). Step DSL is documented in reference.md.",
  "deviceScaleFactor": 2,
  "viewports": {
    "desktop": { "width": 1440, "height": 900 },
    "mobile": { "width": 390, "height": 844 }
  },
  "projects": {
    "cash-register": {
      "repoDir": "/home/migaloco/Desktop/personal/projects/cash_register",
      "devCommand": "pnpm dev",
      "port": 3000,
      "liveUrl": "https://cash-register-a85839.gitlab.io",
      "imageDir": "cash-register",
      "start": "/",
      "theme": { "strategy": "localStorage+class", "key": "cash-register-theme", "darkClass": "dark" },
      "themes": ["L", "D"],
      "_authNote": "PIN-gated (Festa POS). Real login: select #operator-select (option labelled 'Name (role)'), fill #pin-input, submit 'Iniciar Turno'. Admin PIN in secrets.cashRegister.adminPin reaches /products. Local uses 127.0.0.1 Supabase (not running) → capture against the live deployment. If operators don't load, scenes fall back to capturing the login screen.",
      "login": [
        { "waitFor": "#operator-select" },
        { "select": ["#operator-select", "admin"] },
        { "wait": 400 },
        { "fill": ["#pin-input", "{{secret.cashRegister.adminPin}}"] },
        { "click": "button[type=\"submit\"]" },
        { "wait": 2000 }
      ],
      "marketingOrder": ["register", "orders_list", "products", "payment", "order_detail", "register_mobile"],
      "_usedStateNote": "Capture against LOCAL seeded Supabase so the dashboard has orders and login works (Ana L. / adminPin). Setup: pnpm supabase:start && npx supabase db reset && pnpm supabase:env-sync && node scripts/upload-products-cloud.mjs --local (the seed leaves product image_url NULL — the upload step pushes generated-images/*.webp to local storage and sets image_url, otherwise product cards show placeholder icons). Scenes fill the cart / open payment so nothing shows an empty state.",
      "scenes": [
        { "name": "register", "path": "/", "steps": [
          { "wait": 1300 },
          { "optional": [
            { "click": "button:has-text(\"Cerveja\")" }, { "wait": 250 },
            { "click": "button:has-text(\"Gin tónico\")" }, { "wait": 250 },
            { "click": "button:has-text(\"Sidra\")" }, { "wait": 250 },
            { "click": "button:has-text(\"Caipirão\")" }, { "wait": 300 }
          ] },
          { "shot": "register" }
        ] },
        { "name": "payment", "path": "/", "steps": [
          { "wait": 1300 },
          { "optional": [
            { "click": "button:has-text(\"Cerveja\")" }, { "wait": 220 },
            { "click": "button:has-text(\"Gin tónico\")" }, { "wait": 220 },
            { "click": "button:has-text(\"Sidra\")" }, { "wait": 300 },
            { "click": "button:has-text(\"Confirmar Pedido\")" }, { "wait": 1000 },
            { "click": "button:has-text(\"5€\")" }, { "wait": 400 }
          ] },
          { "shot": "payment" }
        ] },
        { "name": "products", "path": "/products", "settle": 1300 },
        { "name": "orders_list", "path": "/orders", "settle": 1500 },
        { "name": "order_detail", "path": "/orders", "steps": [
          { "wait": 1400 },
          { "optional": [ { "click": "button.bg-card" }, { "wait": 900 } ] },
          { "shot": "order_detail" }
        ] },
        { "name": "register_mobile", "path": "/", "viewport": "mobile", "steps": [
          { "wait": 1300 },
          { "optional": [
            { "click": "button:has-text(\"Cerveja\")" }, { "wait": 250 },
            { "click": "button:has-text(\"Sidra\")" }, { "wait": 300 }
          ] },
          { "shot": "register_mobile" }
        ] }
      ]
    },

